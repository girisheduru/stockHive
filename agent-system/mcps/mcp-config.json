{
  "mcpServers": {
    "yfinance-mcp": {
      "command": "python3",
      "args": ["/data/.openclaw/workspace/stockHive/local-mcp/server.py"],
      "env": { "MCP_MODE": "yfinance", "MCP_SERVER_NAME": "yfinance-mcp", "ALPHA_VANTAGE_API_KEY": "${ALPHA_VANTAGE_API_KEY}" },
      "description": "Local replacement MCP for price history and overview data."
    },
    "alpha-vantage-mcp": {
      "command": "python3",
      "args": ["/data/.openclaw/workspace/stockHive/local-mcp/server.py"],
      "env": { "MCP_MODE": "alpha", "MCP_SERVER_NAME": "alpha-vantage-mcp", "ALPHA_VANTAGE_API_KEY": "${ALPHA_VANTAGE_API_KEY}" },
      "description": "Local replacement MCP for daily history + technical indicators via Alpha Vantage."
    },
    "nasdaq-data-link-mcp": {
      "command": "python3",
      "args": ["/data/.openclaw/workspace/stockHive/local-mcp/server.py"],
      "env": { "MCP_MODE": "nasdaq", "MCP_SERVER_NAME": "nasdaq-data-link-mcp", "NASDAQ_DATA_LINK_API_KEY": "${NASDAQ_DATA_LINK_API_KEY}" },
      "description": "Local replacement MCP for historical EOD prices."
    },
    "news-api-mcp": {
      "command": "python3",
      "args": ["/data/.openclaw/workspace/stockHive/local-mcp/server.py"],
      "env": { "MCP_MODE": "news", "MCP_SERVER_NAME": "news-api-mcp", "NEWS_API_KEY": "${NEWS_API_KEY}" },
      "description": "Local replacement MCP for recent headlines per ticker."
    },
    "telegram-bot-mcp": {
      "command": "python3",
      "args": ["/data/.openclaw/workspace/stockHive/local-mcp/server.py"],
      "env": {
        "MCP_MODE": "telegram",
        "MCP_SERVER_NAME": "telegram-bot-mcp",
        "TELEGRAM_BOT_TOKEN": "${TELEGRAM_BOT_TOKEN}",
        "TELEGRAM_CHAT_ID": "${TELEGRAM_CHAT_ID}",
        "TELEGRAM_MESSAGE_THREAD_ID": "${TELEGRAM_MESSAGE_THREAD_ID}"
      },
      "description": "Local replacement MCP for Telegram publishing."
    }
  }
}
