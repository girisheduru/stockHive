{
  "id": "nasdaq-top-movers",
  "name": "StockHive — Nasdaq 100 Top Movers Analyzer",
  "version": "1.0.0",
  "description": "Daily automated pipeline that ranks the top-10 weekly gainers in the Nasdaq 100, spawns ephemeral technical / fundamental / sentiment subagents, decides bullish or bearish, and posts the top 5 buy candidates to Telegram.",
  "author": "Girish Eduru",
  "platform": "OpenClaw / Claude Cowork",
  "entrypoints": {
    "scheduled": "scheduled-tasks/nasdaq-daily-schedule.json",
    "runner": "scripts/nasdaq-daily-run.sh",
    "orchestrator": "agents/nasdaq-analyst-orchestrator.md"
  },
  "exports": {
    "agents": [
      "agents/nasdaq-analyst-orchestrator.md",
      "agents/data-fetcher.md",
      "agents/technical-analyst.md",
      "agents/fundamental-analyst.md",
      "agents/sentiment-analyst.md",
      "agents/telegram-publisher.md"
    ],
    "skills": [
      "skills/stock-data-fetcher",
      "skills/technical-indicators",
      "skills/fundamental-snapshot",
      "skills/sentiment-analyzer",
      "skills/telegram-formatter"
    ],
    "scheduled_tasks": ["scheduled-tasks/nasdaq-daily-schedule.json"],
    "mcps": ["mcps/mcp-config.json"]
  },
  "requires": {
    "mcps": ["yfinance-mcp", "alpha-vantage-mcp", "nasdaq-data-link-mcp", "news-api-mcp", "telegram-bot-mcp"],
    "env": ["ALPHA_VANTAGE_API_KEY", "NASDAQ_DATA_LINK_API_KEY", "NEWS_API_KEY", "TELEGRAM_BOT_TOKEN", "TELEGRAM_CHAT_ID"]
  }
}
