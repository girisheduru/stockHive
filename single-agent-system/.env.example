# Single-Agent Telegram Flow Environment
# Copy to single-agent-system/.env and fill values.

# Required: Telegram association for this single-agent flow
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Optional: reply inside a specific Telegram topic/thread
TELEGRAM_MESSAGE_THREAD_ID=""

# Optional: runtime limit override (minutes)
MAX_SUBAGENT_RUNTIME_MIN="5"
