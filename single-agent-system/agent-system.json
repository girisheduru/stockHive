{
  "id": "stockhive-telegram-single-ticker",
  "name": "StockHive — Telegram Single Ticker Flow",
  "version": "1.0.0",
  "kind": "agent-system",
  "description": "Runs the same StockHive specialist analysis pipeline for one ticker extracted from an inbound Telegram message.",
  "author": "Girish Eduru",
  "platform": "OpenClaw / Claude Cowork",
  "composition": {
    "orchestrator": {
      "name": "stockhive-telegram-trigger-orchestrator",
      "persistence": "persistent",
      "spec": "single-agent-system/agents/stockhive-telegram-trigger-orchestrator.md"
    },
    "subagents": [
      { "name": "technical-analyst", "persistence": "ephemeral", "spec": "agent-system/agents/technical-analyst.md" },
      { "name": "fundamental-analyst", "persistence": "ephemeral", "spec": "agent-system/agents/fundamental-analyst.md" },
      { "name": "sentiment-analyst", "persistence": "ephemeral", "spec": "agent-system/agents/sentiment-analyst.md" },
      { "name": "telegram-publisher", "persistence": "ephemeral", "spec": "agent-system/agents/telegram-publisher.md" }
    ],
    "skills": [
      "agent-system/skills/technical-indicators",
      "agent-system/skills/fundamental-snapshot",
      "agent-system/skills/sentiment-analyzer",
      "agent-system/skills/telegram-formatter"
    ],
    "scheduled_tasks": [
      "single-agent-system/scheduled-tasks/telegram-single-ticker-poll.json"
    ],
    "mcps": [
      "agent-system/mcps/mcp-config.json"
    ],
    "scripts": [
      "single-agent-system/scripts/extract_ticker.py",
      "agent-system/scripts/decision_engine.py"
    ]
  },
  "requires": {
    "mcps": [
      "yfinance-mcp",
      "alpha-vantage-mcp",
      "nasdaq-data-link-mcp",
      "news-api-mcp",
      "telegram-bot-mcp"
    ],
    "env": [
      "ALPHA_VANTAGE_API_KEY",
      "NASDAQ_DATA_LINK_API_KEY",
      "NEWS_API_KEY",
      "TELEGRAM_BOT_TOKEN",
      "TELEGRAM_CHAT_ID"
    ]
  }
}
