{
  "trigger": "telegram_webhook_event",
  "expect_single_ticker": true,
  "event_payload": {
    "chat_id": "8759086158",
    "message_id": "99999",
    "from_user_id": "8759086158",
    "message_text": "Analyze AAPL"
  },
  "ticker_source": {
    "type": "telegram_message_text",
    "extract_script": "single-agent-system/scripts/extract_ticker.py",
    "universe_file": "agent-system/config/nasdaq100-tickers.json"
  },
  "analysis_pipeline": {
    "specialists": [
      "technical-analyst",
      "fundamental-analyst",
      "sentiment-analyst"
    ],
    "decision_engine": "agent-system/scripts/decision_engine.py",
    "publisher": "telegram-publisher",
    "publish_target": "same_chat_or_sender",
    "reply_to_message_id": true
  }
}
